# Admin password for logging into /admin
ADMIN_PASSWORD=your-secure-password-here

# Optional: separate secret for session signing (falls back to ADMIN_PASSWORD)
SESSION_SECRET=your-random-secret-here

# Turso (edge SQLite) — for post and comment storage
TURSO_DATABASE_URL=libsql://your-db.your-region.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
